{
	"$schema": "../../../node_modules/wrangler/config-schema.json",
	"name": "kody-mock-resend",
	"compatibility_date": "2026-01-31",
	"compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
	"main": "./src/worker.ts",
	"preview_urls": true,
	"observability": { "enabled": true },
	"migrations": [
		{
			"new_classes": ["MockResendMessagesDurableObject"],
			"tag": "v1",
		},
	],
	"durable_objects": {
		"bindings": [
			{
				"class_name": "MockResendMessagesDurableObject",
				"name": "MOCK_RESEND_STATE",
			},
		],
	},
	"env": {
		"production": {
			"durable_objects": {
				"bindings": [
					{
						"class_name": "MockResendMessagesDurableObject",
						"name": "MOCK_RESEND_STATE",
					},
				],
			},
		},
		"preview": {
			"durable_objects": {
				"bindings": [
					{
						"class_name": "MockResendMessagesDurableObject",
						"name": "MOCK_RESEND_STATE",
					},
				],
			},
		},
		"test": {
			"durable_objects": {
				"bindings": [
					{
						"class_name": "MockResendMessagesDurableObject",
						"name": "MOCK_RESEND_STATE",
					},
				],
			},
		},
	},
}
