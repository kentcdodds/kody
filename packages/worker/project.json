{
	"$schema": "../../node_modules/nx/schemas/project-schema.json",
	"name": "worker",
	"projectType": "application",
	"sourceRoot": "packages/worker/src",
	"targets": {
		"dev": {
			"executor": "nx:run-commands",
			"options": {
				"command": "npm run dev"
			}
		},
		"build-codemode-sandbox-modules": {
			"executor": "nx:run-commands",
			"outputs": [
				"{workspaceRoot}/packages/worker/src/mcp/generated/codemode-sandbox-modules.ts"
			],
			"options": {
				"command": "npm run build:codemode-sandbox-modules"
			}
		},
		"dev-client": {
			"executor": "nx:run-commands",
			"options": {
				"command": "npm run dev:client"
			}
		},
		"dev-worker": {
			"executor": "nx:run-commands",
			"options": {
				"command": "npm run dev:worker"
			}
		},
		"build-client-web": {
			"executor": "nx:run-commands",
			"outputs": [
				"{workspaceRoot}/packages/worker/public/client-entry.js",
				"{workspaceRoot}/packages/worker/public/assets"
			],
			"options": {
				"command": "npm run build:client:web"
			}
		},
		"build-mcp-apps": {
			"executor": "nx:run-commands",
			"outputs": ["{workspaceRoot}/packages/worker/public/mcp-apps"],
			"options": {
				"command": "npm run build:mcp-apps"
			}
		},
		"build-client": {
			"executor": "nx:run-commands",
			"dependsOn": ["build-codemode-sandbox-modules"],
			"outputs": [
				"{workspaceRoot}/packages/worker/public/client-entry.js",
				"{workspaceRoot}/packages/worker/public/assets",
				"{workspaceRoot}/packages/worker/public/mcp-apps"
			],
			"options": {
				"command": "npm run build:client"
			}
		},
		"build": {
			"executor": "nx:run-commands",
			"dependsOn": ["build-codemode-sandbox-modules", "build-client"],
			"options": {
				"command": "npm run build"
			}
		},
		"deploy": {
			"executor": "nx:run-commands",
			"options": {
				"command": "npm run deploy"
			}
		},
		"migrate-local": {
			"executor": "nx:run-commands",
			"options": {
				"command": "npm run migrate:local"
			}
		},
		"migrate-e2e": {
			"executor": "nx:run-commands",
			"options": {
				"command": "npm run migrate:e2e"
			}
		},
		"preview": {
			"executor": "nx:run-commands",
			"options": {
				"command": "npm run preview"
			}
		},
		"preview-e2e": {
			"executor": "nx:run-commands",
			"options": {
				"command": "npm run preview:e2e"
			}
		},
		"generate-types": {
			"executor": "nx:run-commands",
			"options": {
				"command": "npm run generate-types"
			}
		}
	},
	"tags": ["scope:worker"]
}
