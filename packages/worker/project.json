{
	"$schema": "../../node_modules/nx/schemas/project-schema.json",
	"name": "worker",
	"projectType": "application",
	"sourceRoot": "packages/worker/src",
	"targets": {
		"dev": {
			"executor": "nx:run-commands",
			"options": {
				"command": "npm run dev"
			}
		},
		"dev-client": {
			"executor": "nx:run-commands",
			"options": {
				"command": "npm run dev:client"
			}
		},
		"dev-worker": {
			"executor": "nx:run-commands",
			"options": {
				"command": "npm run dev:worker"
			}
		},
		"build-client-web": {
			"executor": "nx:run-commands",
			"outputs": [
				"{workspaceRoot}/packages/worker/public/client-entry.js",
				"{workspaceRoot}/packages/worker/public/assets"
			],
			"options": {
				"command": "npm run build:client:web"
			}
		},
		"build-mcp-apps": {
			"executor": "nx:run-commands",
			"outputs": ["{workspaceRoot}/packages/worker/public/mcp-apps"],
			"options": {
				"command": "npm run build:mcp-apps"
			}
		},
		"build-client": {
			"executor": "nx:run-commands",
			"dependsOn": ["build-codemode-helpers"],
			"outputs": [
				"{workspaceRoot}/packages/worker/public/client-entry.js",
				"{workspaceRoot}/packages/worker/public/assets",
				"{workspaceRoot}/packages/worker/public/mcp-apps"
			],
			"options": {
				"command": "npm run build:client"
			}
		},
		"build": {
			"executor": "nx:run-commands",
			"dependsOn": ["build-codemode-sandbox-modules", "build-client"],
			"options": {
				"command": "node --env-file=packages/worker/.env ./wrangler-env.ts build"
			}
		},
		"build-codemode-helpers": {
			"executor": "nx:run-commands",
			"inputs": [
				"default",
				"{workspaceRoot}/packages/worker/src/mcp/execute-modules/codemode-utils.ts",
				"{workspaceRoot}/package.json",
				"{workspaceRoot}/package-lock.json"
			],
			"options": {
				"command": "node -e \"process.exit(0)\""
			}
		},
		"typecheck": {
			"executor": "nx:run-commands",
			"dependsOn": ["build-codemode-helpers"],
			"options": {
				"command": "tsc -b --noEmit"
			}
		},
		"test": {
			"executor": "nx:run-commands",
			"dependsOn": ["build-codemode-helpers"],
			"options": {
				"command": "vitest run --project node-unit --project workers-unit"
			}
		},
		"test-mcp": {
			"executor": "nx:run-commands",
			"dependsOn": ["build-codemode-helpers", "build-mcp-apps"],
			"options": {
				"command": "node tools/prepare-e2e-env.ts && vitest run --project mcp-e2e"
			}
		},
		"deploy": {
			"executor": "nx:run-commands",
			"options": {
				"command": "npm run deploy"
			}
		},
		"migrate-local": {
			"executor": "nx:run-commands",
			"options": {
				"command": "npm run migrate:local"
			}
		},
		"migrate-e2e": {
			"executor": "nx:run-commands",
			"options": {
				"command": "npm run migrate:e2e"
			}
		},
		"preview": {
			"executor": "nx:run-commands",
			"options": {
				"command": "npm run preview"
			}
		},
		"preview-e2e": {
			"executor": "nx:run-commands",
			"options": {
				"command": "npm run preview:e2e"
			}
		},
		"generate-types": {
			"executor": "nx:run-commands",
			"options": {
				"command": "npm run generate-types"
			}
		}
	},
	"tags": ["scope:worker"]
}
