# Example environment variables for local dev, test, and preview deploys.
# Copy this to `packages/worker/.env` for local development and local tests.

# Required
COOKIE_SECRET=LOCAL_AND_PREVIEW_COOKIE_SECRET_32_CHARS_MINIMUM

# Optional (preview uses request origin by default)
APP_BASE_URL=

# Resend (optional; preview deploys overwrite these to point at the mock services)
RESEND_API_BASE_URL=
RESEND_API_KEY=
RESEND_FROM_EMAIL=reset@kody.dev

# AI chat runtime (optional examples)
# AI_MODE=remote
# AI_MODEL=@cf/zai-org/glm-4.7-flash
# AI_GATEWAY_ID=your-cloudflare-ai-gateway-id
# CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
# CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# Sentry (optional; omit locally if you are not sending errors to Sentry)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=development
# Optional: omit for 1.0 (default, sample all traces). Lower only if traffic grows.
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Sentry source map upload (local or CI - not Worker secrets)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug

# Cloudflare API / Browser Rendering (optional; `npm run dev` sets a mock URL + token for `cloudflare_rest`)
# Uses Authorization: Bearer <token> against /client/v4/* endpoints.
# Reuse `CLOUDFLARE_API_TOKEN` for the live API. In mock mode `npm run dev` injects a local token.
# page_to_markdown also needs CLOUDFLARE_ACCOUNT_ID when it falls back to Cloudflare Browser Rendering `/markdown`.
# CLOUDFLARE_API_BASE_URL=https://api.cloudflare.com
# Skip starting the Cloudflare mock during dev (use live API + token in `packages/worker/.env` instead):
# SKIP_CLOUDFLARE_MOCK=1

# Capability + skill vector search (optional Worker secret).
# POST /__maintenance/reindex-capabilities and /__maintenance/reindex-skills with
# Authorization: Bearer <this value> repopulates Vectorize after deploys. CI can set
# GitHub secret CAPABILITY_REINDEX_SECRET and sync it via deploy workflow.
# CAPABILITY_REINDEX_SECRET=
