# Example environment variables for local dev, test, and preview deploys.
# Copy this to `.env` for local development and local tests.

# Required
COOKIE_SECRET=LOCAL_AND_PREVIEW_COOKIE_SECRET_32_CHARS_MINIMUM

# Optional (preview uses request origin by default)
APP_BASE_URL=

# Resend (optional; preview deploys overwrite these to point at the mock services)
RESEND_API_BASE_URL=
RESEND_API_KEY=
RESEND_FROM_EMAIL=reset@kody.dev

# AI chat runtime (optional examples)
# AI_MODE=remote
# AI_MODEL=@cf/zai-org/glm-4.7-flash
# AI_GATEWAY_ID=your-cloudflare-ai-gateway-id
# CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
# CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# Sentry (optional; omit locally if you are not sending errors to Sentry)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=development
# Optional: omit for 1.0 (default, sample all traces). Lower only if traffic grows.
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Sentry source map upload (local or CI — not Worker secrets)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug

# GitHub (optional; `bun run dev` sets a mock API URL + token for the `github_rest` capability)
# For production, use a fine-grained PAT for the `kody-bot` account synced as the Worker secret
# `GITHUB_TOKEN` (in GitHub Actions use repo secret `KODY_GITHUB_TOKEN`; deploy maps it to
# `GITHUB_TOKEN`).
# GITHUB_TOKEN=
# GITHUB_API_BASE_URL=https://api.github.com
# Skip starting the GitHub mock during dev (use live API + PAT in .env instead):
# SKIP_GITHUB_MOCK=1

