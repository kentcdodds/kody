# Example environment variables for local dev, test, and preview deploys.
# Copy this to `.env` for local development and local tests.

# Required
COOKIE_SECRET=LOCAL_AND_PREVIEW_COOKIE_SECRET_32_CHARS_MINIMUM

# Optional (preview uses request origin by default)
APP_BASE_URL=

# Resend (optional; preview deploys overwrite these to point at the mock services)
RESEND_API_BASE_URL=
RESEND_API_KEY=
RESEND_FROM_EMAIL=reset@kody.dev

# AI chat runtime (optional examples)
# AI_MODE=remote
# AI_MODEL=@cf/zai-org/glm-4.7-flash
# AI_GATEWAY_ID=your-cloudflare-ai-gateway-id
# CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
# CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
# CLOUDFLARE_API_BASE_URL=https://api.cloudflare.com

# Sentry (optional; omit locally if you are not sending errors to Sentry)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=development
# Optional: omit for 1.0 (default, sample all traces). Lower only if traffic grows.
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Sentry source map upload (local or CI — not Worker secrets)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug

# GitHub (optional; `bun run dev` sets a mock API URL + token for the `github_rest` + `github_graphql` capabilities)
# For production, use a fine-grained PAT for the `kody-bot` account synced as the Worker secret
# `GITHUB_TOKEN` (in GitHub Actions use repo secret `KODY_GITHUB_TOKEN`; deploy maps it to
# `GITHUB_TOKEN`).
# GITHUB_TOKEN=
# GITHUB_API_BASE_URL=https://api.github.com
# Skip starting the GitHub mock during dev (use live API + PAT in .env instead):
# SKIP_GITHUB_MOCK=1

# Cursor Cloud Agents API (optional; `bun run dev` sets a mock URL + key for `cursor_cloud_rest`)
# API key from https://cursor.com/settings — HTTP Basic (key as username, empty password).
# CURSOR_API_KEY=
# CURSOR_API_BASE_URL=https://api.cursor.com
# Skip starting the Cursor mock during dev (use live API + key in .env instead):
# SKIP_CURSOR_MOCK=1

# Cloudflare API (optional; `bun run dev` sets a mock URL + token for `cloudflare_rest`)
# Uses Authorization: Bearer <token> against /client/v4/* endpoints.
# Reuse `CLOUDFLARE_API_TOKEN` for the live API. In mock mode `bun run dev` injects a local token.
# CLOUDFLARE_API_BASE_URL=https://api.cloudflare.com
# Skip starting the Cloudflare mock during dev (use live API + token in .env instead):
# SKIP_CLOUDFLARE_MOCK=1

# Capability vector search (optional Worker secret). POST /__maintenance/reindex-capabilities
# with Authorization: Bearer <this value> repopulates Vectorize after deploys. CI can set
# GitHub secret CAPABILITY_REINDEX_SECRET and sync it via deploy workflow.
# CAPABILITY_REINDEX_SECRET=

