{
	"$schema": "./node_modules/nx/schemas/nx-schema.json",
	"defaultBase": "main",
	"workspaceLayout": {
		"libsDir": "packages"
	},
	"targetDefaults": {
		"build": {
			"cache": true
		},
		"build-client": {
			"cache": true
		},
		"build-client-web": {
			"cache": true
		},
		"build-mcp-apps": {
			"cache": true
		},
		"test": {
			"cache": true
		},
		"test-mcp": {
			"cache": true
		},
		"prepare-e2e-env": {
			"cache": true
		},
		"prepare-playwright": {
			"cache": false
		},
		"test-e2e": {
			"cache": true
		},
		"dev": {
			"cache": false
		},
		"dev-client": {
			"cache": false
		},
		"dev-worker": {
			"cache": false
		},
		"preview": {
			"cache": false
		},
		"preview-e2e": {
			"cache": false
		}
